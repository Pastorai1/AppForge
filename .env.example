# ───────────────────────────────────────────────────────────────
# AppForge environment variables
#
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real secrets.
#
# IMPORTANT: AppForge is designed to use its OWN isolated
# Supabase project, Stripe account, and Anthropic key — separate
# from any other app (e.g. Pastor AI / Ready Room). Do not reuse
# credentials across apps.
# ───────────────────────────────────────────────────────────────

# ── Supabase (auth + database) ──
# Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (sb_publishable_…) — safe to expose to the browser.
# (Legacy projects: use the "anon public" key here instead.)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key
# Server-only. Keep secret. Used by webhooks / privileged writes.
# Secret key (sb_secret_…) — never expose to the browser.
# (Legacy projects: use the "service_role" key here instead.)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key

# ── Anthropic (AI — SERVER SIDE ONLY) ──
# Never expose this to the browser. Only used in /app/api/** route handlers.
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Stripe (billing) ──
STRIPE_SECRET_KEY=sk_test_your-key
# Publishable key is safe to expose to the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Price ID for the Pro plan ($9/mo). Create it in the Stripe dashboard.
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# ── App ──
# The public base URL of this deployment (used for Stripe redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000
